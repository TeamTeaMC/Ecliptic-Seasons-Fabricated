{
  "replace": true,
  "multipart": [
    {
      "when": {
        "age": "0"
      },
      "apply": [
        {
          "model": "eclipticseasons:block/snowy/bamboo1_age0"
        },
        {
          "model": "eclipticseasons:block/snowy/bamboo2_age0"
        },
        {
          "model": "eclipticseasons:block/snowy/bamboo3_age0"
        },
        {
          "model": "eclipticseasons:block/snowy/bamboo4_age0"
        }
      ]
    },
    {
      "when": {
        "age": "1"
      },
      "apply": [
        {
          "model": "eclipticseasons:block/snowy/bamboo1_age1"
        },
        {
          "model": "eclipticseasons:block/snowy/bamboo2_age1"
        },
        {
          "model": "eclipticseasons:block/snowy/bamboo3_age1"
        },
        {
          "model": "eclipticseasons:block/snowy/bamboo4_age1"
        }
      ]
    },
    {
      "when": {
        "leaves": "large"
      },
      "apply": {
        "model": "eclipticseasons:block/snowy/bamboo_large_leaves"
      }
    },
    {
      "when": {
        "leaves": "small"
      },
      "apply": {
        "model": "eclipticseasons:block/snowy/bamboo_small_leaves"
      }
    }
  ]
}